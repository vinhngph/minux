#!/bin/bash

CONF_FILE="$HOME/.config/pipewire/filter-chain.conf.d/aec-deepfilternet.conf"
CONF_FILE_DISABLED="$HOME/.config/pipewire/filter-chain.conf.d/aec-deepfilternet.conf.disabled"
CMD="pipewire -c filter-chain.conf"

cleanup() {
    echo ""
    echo "[-] Disabling DeepFilterNet..."

    if [ -f "$CONF_FILE" ]; then
        mv "$CONF_FILE" "$CONF_FILE_DISABLED"
        echo "[-] Changed to .disabled"
    fi

    echo "[-] Disabled."
    exit 0   
}

trap cleanup SIGINT SIGTERM

if [ -f "$CONF_FILE_DISABLED" ]; then
    mv "$CONF_FILE_DISABLED" "$CONF_FILE"
    echo "[-] DeepFilterNet + Echo Cancel: Enabled"
elif [ -f "$CONF_FILE" ]; then
    echo "[-] DeepFilterNet + Echo Cancel: Already enabled"
else
    echo "[-] Cannot find $CONF_FILE"
    exit 1
fi

echo "[-] Press Ctrl + C to disable"

$CMD

cleanup